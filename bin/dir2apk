#!/bin/bash

IPK2APK=ipk2apk
[ -n "$(which ipk2apk)" ] || IPK2APK="$(dirname "$0")/ipk2apk"

show_help() {
	cat << EOF
Usage: $(basename "$0") <IPK_DIR> [OUTPUT_DIR]

Arguments:
  <IPK_DIR>          Directory containing .ipk files to be converted.
  [OUTPUT_DIR]       Target directory for .apk files (default: current dir).

EOF
}

script_dir() {
	local src="$0"
	if [[ "$src" == */* ]]; then
		:
	else
		src="$(which "$src")"
		[ -z "$src" ] && { echo "Error: $src not found in PATH" >&2; exit 1; }
	fi
	echo "$(dirname "$(readlink -f "$src")")"
}

fallback_to_docker_if_needed() {
	[ -z "$(which apk)" -o -z "$(which fakeroot)" ] || return 0
	echo "apk or fakeroot command not found in PATH, fallback to docker"
	local docker_fake_root="$(readlink -f "$(script_dir)/../docker")"
	"$docker_fake_root/init.sh" "$1" || { echo "docker fallback path failed!"; exit 1; }
	export PATH="$docker_fake_root/bin:$PATH"
}

convert_one_dir() {
	local input_dir="${1%/}"
	local output_dir="${2%/}"
	[ ! -d "$input_dir" ] && { echo "Error: $input_dir not found"; return 1; }

	fallback_to_docker_if_needed "$output_dir"

	local ipk_file rel_path target_dir
	# find all .ipk files and convert them, reserve directory structure
	find "$input_dir" -type f -name "*.ipk" | while read; do
		ipk_file="$REPLY"
		rel_path="${ipk_file#$input_dir/}"
		target_dir="$output_dir/$(dirname "$rel_path")"
		mkdir -p "$target_dir"
		"$IPK2APK" "$ipk_file" "$target_dir"
	done
}

[ "$#" -ne 1 ] && [ "$#" -ne 2 ] && { show_help; exit 0; }

if [ "$#" -eq 1 ]; then
	convert_one_dir "$1" "$(pwd)"
else
	convert_one_dir "$1" "$2"
fi
