#!/bin/bash
# convert version to apk compatible version

srcver="$1"
if [ -z "$srcver" ]; then
	echo "Usage: $0 <VERSION_STRING>"
	exit 1
fi

TAB=$(echo -e "\t")

script_dir() {
	local src="$0"
	if [[ "$src" == */* ]]; then
		:
	else
		src="$(which "$src")"
		[ -z "$src" ] && { echo "Error: $src not found in PATH" >&2; exit 1; }
	fi
	echo "$(dirname "$(readlink -f "$src")")"
}

vermap_file="$(script_dir)/../data/vermap.tsv"

# fix version string to be compatible with apk versioning scheme
# first check ../data/vermap.tsv, if found, use the mapping in that file, otherwise, use the following rules to convert version string:
# 4.0.10 -> 4.0.10
# 2.19.5-r1 -> 2.19.5-r1
# 4.2.1~aa64-r4 -> 4.2.1~aa64-r4
# 0.7.5-aa64-1 -> 0.7.5~aa64-r1
# 660-1 -> 660-r1
# 1.2.0-aarch64-1 -> 1.2.0~aa64-r1
# 1.2.0-x86_64-1 -> 1.2.0~8664-r1
# 4.6.7.10-1 -> 4.6.7.10-r1
# 2023-01-21-a8c16319-1 -> 2023.01.21~a8c16319-r1
# git-23.072.37344-dadcf42 -> 23.072.37344~dadcf42
# unknown -> 0.0.1

if [[ unknown == "$srcver" ]]; then
	apkver="0.0.1"
else
	apkver=$(awk -F "$TAB" -v src="$srcver" '$1 == src { print $2; exit }' "$vermap_file")
fi

if [ -n "$apkver" ]; then
	echo "$apkver"
	exit 0
fi

if [[ "$srcver" =~ ^([0-9]{4})-([0-9]{2})-([0-9]{2})(-.+)?$ ]]; then
	srcver="${BASH_REMATCH[1]}.${BASH_REMATCH[2]}.${BASH_REMATCH[3]}${BASH_REMATCH[4]}"
elif [[ "$srcver" =~ ^git-(.+)$ ]]; then
	srcver="${BASH_REMATCH[1]}"
elif [[ "$srcver" =~ ^v(.+)$ ]]; then
	srcver="${BASH_REMATCH[1]}"
fi

if [[ "$srcver" =~ ^(.+)-aarch64-(.+)$ ]]; then
	srcver="${BASH_REMATCH[1]}-aa64-${BASH_REMATCH[2]}"
elif [[ "$srcver" =~ ^(.+)-x86_64-(.+)$ ]]; then
	srcver="${BASH_REMATCH[1]}-8664-${BASH_REMATCH[2]}"
fi

if [[ "$srcver" =~ ^([0-9]+(\.[0-9]+)*)([~-]([a-fA-F0-9]+))(-r?([0-9]+))$ ]]; then
	apkver="${BASH_REMATCH[1]}~${BASH_REMATCH[4]}-r${BASH_REMATCH[6]}"
elif [[ "$srcver" =~ ^([0-9]+(\.[0-9]+)*)(-r?([0-9]+))$ ]]; then
	apkver="${BASH_REMATCH[1]}-r${BASH_REMATCH[4]}"
elif [[ "$srcver" =~ ^([0-9]+(\.[0-9]+)*)([~-]([a-fA-F0-9]+))?(-r?([0-9]+))?$ ]]; then
	apkver="${BASH_REMATCH[1]}"
	if [ -n "${BASH_REMATCH[4]}" ]; then
		apkver+="~${BASH_REMATCH[4]}"
	fi
	if [ -n "${BASH_REMATCH[5]}" ]; then
		apkver+="-r${BASH_REMATCH[6]}"
	fi
fi

if [ -n "$apkver" ]; then
	echo "$apkver"
	exit 0
fi

exit 1
